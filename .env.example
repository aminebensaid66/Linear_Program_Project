LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_ai_studio_key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_MODEL_PARSE=gemini-2.0-flash
GOOGLE_MODEL_EXPLAIN=gemini-2.0-flash

