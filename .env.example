DEEPSEEK_MODEL_EXPLAIN=deepseek-chat

# Optional generic overrides
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_PARSE=
LLM_MODEL_EXPLAIN=
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_MS=1200

PYTHON_SOLVER_URL=http://python-solver:8000
FRONTEND_URL=http://localhost:5173
PORT=3000